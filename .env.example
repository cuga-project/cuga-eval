# CUGA Evaluation Framework — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored and should never be committed.

# ── LLM Provider API Keys ──────────────────────────────────────
# At least one provider key is required.

# Groq (default provider for gpt-oss profile)
GROQ_API_KEY="your-groq-api-key"

# OpenAI
# OPENAI_API_KEY="your-openai-api-key"

# Azure OpenAI
# AZURE_OPENAI_API_KEY="your-azure-key"
# AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com"

# Anthropic
# ANTHROPIC_API_KEY="your-anthropic-key"

# ── Model Configuration ────────────────────────────────────────
# Default model settings. Override per-run with --model-profile.
AGENT_SETTING_CONFIG=settings.groq.toml
MODEL_NAME=openai/gpt-oss-120b

# ── Langfuse Tracing (Optional) ────────────────────────────────
# Enables detailed LLM call tracing, token counts, and cost tracking.
# Get keys from your Langfuse instance (Settings > API Keys).
DYNACONF_ADVANCED_FEATURES__LANGFUSE_TRACING=true
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_HOST="https://us.cloud.langfuse.com"
# For local Langfuse: LANGFUSE_HOST="http://localhost:3000"
