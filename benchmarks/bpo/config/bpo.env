# BPO benchmark specific configuration
# These are not secrets and should be committed to the repository

# Registry and logging paths
MCP_SERVERS_FILE="benchmarks/bpo/mcp_servers/bpo.yaml"
CUGA_LOGGING_DIR=benchmarks/bpo/logging
DYNACONF_ADVANCED_FEATURES__REFLECTION_ENABLED=false
DYNACONF_ADVANCED_FEATURES__REGISTRY=true
DYNACONF_POLICY__ENABLED=true
DYNACONF_ADVANCED_FEATURES__BENCHMARK=bpo
DYNACONF_ADVANCED_FEATURES__FORCE_AUTONOMOUS_MODE=true
