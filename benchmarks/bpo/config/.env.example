# BPO Benchmark Environment Variables
# Copy to .env and fill in your values. Never commit secrets.

# ─── Model Selection ───────────────────────────────────────────
# Which CUGA settings file to use (relative to cuga-agent config dir)
AGENT_SETTING_CONFIG=settings.groq.toml

# Model name override (used by some profiles)
MODEL_NAME=groq/llama-3.3-70b-versatile

# ─── LiteLLM / Azure (for OpenAI-compatible profiles) ─────────
# OPENAI_BASE_URL=https://your-endpoint.openai.azure.com/
# OPENAI_API_VERSION=2024-08-06

# ─── API Keys (set in shell or .env, never commit) ────────────
# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Langfuse Observability (optional) ─────────────────────────
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── BPO-specific ─────────────────────────────────────────────
BPO_LOG_API_CALLS=false

# ─── Dynaconf Overrides ───────────────────────────────────────
# These override CUGA settings at runtime via environment variables
DYNACONF_POLICY__ENABLED=true
DYNACONF_ADVANCED_FEATURES__TRACKER_ENABLED=true
DYNACONF_ADVANCED_FEATURES__FORCE_AUTONOMOUS_MODE=true
