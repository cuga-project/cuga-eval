# Appworld benchmark specific configuration
# These are not secrets and should be committed to the repository

# config_loader defaults LOGURU_LEVEL to WARNING otherwise — hides logger.info in eval loops.
LOGURU_LEVEL=DEBUG

APPWORLD_ROOT="benchmarks/appworld/appworld"
MCP_SERVERS_FILE="benchmarks/appworld/mcp_servers_appworld.yaml"
DYNACONF_ADVANCED_FEATURES__REFLECTION_ENABLED=true
DYNACONF_ADVANCED_FEATURES__FORCE_LITE_MODE_APPS=["supervisor","gmail","file_system"]
EVAL_CONFIG_TOML_PATH="benchmarks/appworld/eval_config.toml"
DYNACONF_ADVANCED_FEATURES__DECOMPOSITION_STRATEGY=exact
DYNACONF_ADVANCED_FEATURES__BENCHMARK=appworld
DYNACONF_ADVANCED_FEATURES__FORCE_AUTONOMOUS_MODE=true
DYNACONF_CONTEXT_SUMMARIZATION__ENABLED=false
DYNACONF_ADVANCED_FEATURES__ENABLE_TODOS=false
DYNACONF_ADVANCED_FEATURES__CUGA_LITE_NL_AUTO_CONTINUE=true
DYNACONF_FEATURES__CUGA_MODE=accurate
DYNACONF_ADVANCED_FEATURES__REGISTRY=true
DYNACONF_FEATURES__LOCAL_SANBDOX=true
DYNACONF_ADVANCED_FEATURES__SHORTLISTING_TOOL_THRESHOLD=1
DYNACONF_ADVANCED_FEATURES__LITE_MODE_TOOL_THRESHOLD=500
DYNACONF_ADVANCED_FEATURES__LITE_MODE=true
DYNACONF_SERVER_PORTS__APIS_URL=9111
CUGA_LOGGING_DIR="benchmarks/appworld/logging"
DYNACONF_POLICY__ENABLED=false
